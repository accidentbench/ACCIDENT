# Simulation output directory
OUTPUT_DIR="../../runs/out"

# Select scenarios to simulate
SCENARIO_DIR=/src/client/scenarios/accident-benchmark
## Supports list of file names, divided by ",". It uses glob to match file names, so use can use wild cards.
SELECTED_SCENARIO_CONFIGS="Town05_L02*"

# Image format of simulated images: png, jpg
IMAGE_FORMAT=png

# Run pygame, draw and save annotated images during the simulation
DRAW_DATA=True
# Add LiDAR sensor and save output.
USE_LIDAR=False

# Produce video from frames after a single run from the scenario is simulated
PRODUCE_VIDEOS=True
# Remove run if there was no collision
REMOVE_NO_COLLISIONS=True
# Remove captured frames after a single run (useful if video is generated to free space)
REMOVE_ORIGINAL_SIM_DATA=True

# Use docker to run and restart simulations
USE_DOCKER=True
# Docker container name
CARLA_HOST_NAME=carla-simulator
# Docker container port
CARLA_PORT=2000

# Select a frame since the start of the simulation from which to capture the data.
# Let created objects to set/stabilize before recording by adjusting start frame of the recording.
START_RECORDING_FRAME=20

# Annotation info
CLASS_MAPPING_PATH=/src/client/config/class_mapping.json
COCO_ANNOTATION_TEMPLATE_PATH=/src/client/default_annotation_template.json
# Supported formats are ultralytics, coco
ANNOTATION_FORMAT=ultralytics
